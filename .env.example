# ============================================================
# .env (raíz del proyecto) — variables para VITE (cliente/navegador)
# Copiá este archivo a ".env" y completá con tus datos reales.
# Se consumen en src/lib/supabase-api.js vía import.meta.env.*
#
# ⚠️ Estas dos quedan EXPUESTAS en el bundle del navegador (es
# normal: la anon key está pensada para eso, RLS es lo que protege
# los datos). NUNCA pongas acá la service_role key.
# ============================================================
VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_ANON_KEY_PUBLICA

# ============================================================
# Variables SOLO para scripts/import-places.js (Node, no Vite)
# Van en un .env aparte en la raíz (dotenv/config las lee igual,
# pero NUNCA deben tener el prefijo VITE_ ni terminar en el bundle
# del navegador). Podés dejarlas en este mismo archivo .env local
# porque Vite ignora todo lo que no empieza con VITE_, pero NO
# subas este archivo con la key real a ningún repo público.
# ============================================================
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=TU_SERVICE_ROLE_KEY_SECRETA
